{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2024"],
    "types": ["node"],
    "target": "ES2024",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true
  },
  "include": ["src/**/*.ts"]
}
