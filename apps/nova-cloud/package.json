{
  "name": "nova-cloud",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vp dev",
    "surreal:start": "bash ./scripts/start-surreal.sh",
    "surreal:reset": "rm -rf ./surreal/data",
    "build": "BETTER_AUTH_SECRET=build-placeholder vp build",
    "preview": "node build",
    "prepare": "vp config && svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "test:e2e:skills:setup": "git worktree add -B test/skills-e2e ../nova-sveltekit-test 2>/dev/null || echo 'Worktree already exists'",
    "test:e2e:skills": "bun --cwd ../nova-sveltekit-test playwright test --project=skills-ui,skills-search,skills-chat",
    "test:e2e:skills:ui": "bun --cwd ../nova-sveltekit-test playwright test skills-ui",
    "test:e2e:skills:search": "bun --cwd ../nova-sveltekit-test playwright test skills-search",
    "test:e2e:skills:chat": "bun --cwd ../nova-sveltekit-test playwright test skills-chat",
    "serve:test": "bun --cwd ../nova-sveltekit-test dev",
    "deploy": "vp run build"
  },
  "dependencies": {
    "@ai-sdk/svelte": "^4.0.97",
    "@openrouter/ai-sdk-provider": "^2.2.3",
    "@shikijs/langs": "^3.22.0",
    "@shikijs/themes": "^3.22.0",
    "@xenova/transformers": "^2.17.2",
    "@zvec/zvec": "^0.2.0",
    "ai": "^6.0.97",
    "better-auth": "1.5.3",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "isomorphic-dompurify": "^2.36.0",
    "marked": "^17.0.3",
    "resend": "^6.12.3",
    "runed": "^0.31.1",
    "shiki": "^3.22.0",
    "surrealdb-better-auth": "^0.0.18",
    "svelte-streamdown": "^3.0.1",
    "svelte-toolbelt": "^0.10.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fontsource/fira-mono": "^5.2.7",
    "@internationalized/date": "^3.10.0",
    "@lucide/svelte": "^0.561.0",
    "@neoconfetti/svelte": "^2.2.2",
    "@playwright/test": "^1.58.2",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/table-core": "^8.21.3",
    "@types/node": "^25.4.0",
    "bits-ui": "^2.16.0",
    "clsx": "^2.1.1",
    "embla-carousel-svelte": "^8.6.0",
    "formsnap": "^2.0.1",
    "jsrepo": "^3.6.1",
    "layerchart": "2.0.0-next.43",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
    "svelte-sonner": "^1.0.7",
    "sveltekit-superforms": "^2.28.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
