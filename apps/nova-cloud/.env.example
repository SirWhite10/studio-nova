# SurrealDB Configuration (P2-01)
# Hosted production endpoint from Factory / your Surreal Cloud instance
SURREALDB_URL=wss://brave-comet-....surrealdb.cloud
SURREALDB_NAMESPACE=main
SURREALDB_DATABASE=main
SURREALDB_USERNAME=your_username
SURREALDB_PASSWORD=your_password
SURREALDB_CONNECT_TIMEOUT_MS=5000

# Better Auth
BETTER_AUTH_SECRET=your-super-secret-key-here-min-32-chars
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL="DLX Studios <support@dlxstudios.com>"

# Public site URL (used by Better Auth for cookie domains / redirects)
# Dev: https://devnova.dlxstudios.com
# Prod: https://nova.dlxstudios.com
PUBLIC_SITE_URL=https://devnova.dlxstudios.com

# Optional comma-separated super admin allowlist for chat debug tools
NOVA_SUPER_ADMIN_EMAILS=sir@dlxstudios.com

# Internal cron trigger auth for unattended scheduled jobs.
# Set this in deployment secrets for your runtime environment.
NOVA_CRON_SECRET=replace-with-a-long-random-secret
NOVA_APP_URL=http://localhost:8105

OPENROUTER_API_KEY=sk-...
E2B_API_KEY=...

# Experimental self-hosted K3s runtime control plane
NOVA_RUNTIME_CONTROL_URL=http://127.0.0.1:8787
NOVA_RUNTIME_CONTROL_TOKEN=replace-with-runtime-control-token
