{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "surrealdb-docs-debug request",
  "type": "object",
  "required": ["project_root", "target_app_path"],
  "additionalProperties": false,
  "properties": {
    "project_root": {
      "type": "string",
      "description": "Absolute or repo-relative project root."
    },
    "target_app_path": {
      "type": "string",
      "description": "App path where tests and implementation are evaluated."
    },
    "tests_dir": {
      "type": "string",
      "default": "tests",
      "description": "Target app tests directory for SurrealDB TypeScript preflight files."
    },
    "docs_entry_url": {
      "type": "string",
      "default": "https://surrealdb.com/docs/sdk/javascript/concepts/connecting-to-surrealdb",
      "description": "Canonical SurrealDB documentation entry URL."
    },
    "validation_command_preference": {
      "type": "string",
      "enum": ["auto", "vp", "bun", "npm"],
      "default": "auto"
    },
    "gate_mode": {
      "type": "string",
      "enum": ["type_or_surreal_errors", "strict"],
      "default": "type_or_surreal_errors",
      "description": "Block policy before app implementation."
    },
    "typecheck_cmd": {
      "type": "string",
      "description": "Optional override command for type/app checks."
    },
    "test_runner_cmd": {
      "type": "string",
      "description": "Optional override command for running tests."
    }
  }
}
